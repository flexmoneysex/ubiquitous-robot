            })

            label({Text = title, Size = UDim2.new(1, 0, 0, 22), Parent = frame, ZIndex = 7})

            local container = create("Frame", {
                BackgroundTransparency = 1,
                Position = UDim2.fromOffset(8, 26),
                Size = UDim2.new(1, -12, 1, -28),
                Parent = frame,
                ZIndex = 7
            })

            create("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 0), Parent = container})

            local gb = setmetatable({Frame = frame, Container = container}, GroupboxMeta)
            task.defer(function() updateGroupbox(gb) end)
            return gb
        end

        function tab:AddLeftGroupbox(title)
            local gb = addGroupbox(left, title)
            self.Groupboxes[title] = gb
            return gb
        end

        function tab:AddRightGroupbox(title)
            local gb = addGroupbox(right, title)
            self.Groupboxes[title] = gb
            return gb
        end

        function tab:ShowTab()
            for _, other in pairs(win.Tabs) do
                other.Frame.Visible = false
                other.Button.BackgroundColor3 = Library.BackgroundColor
            end
            tabFrame.Visible = true
            tabButton.BackgroundColor3 = Library.MainColor
        end

        tab.Frame = tabFrame
        tab.Button = tabButton

        tabButton.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then tab:ShowTab() end
        end)

        win.Tabs[name] = tab

        if not firstTab then
            firstTab = tab
            tab:ShowTab()
        end

        return tab
    end

    function win:AddConfigTab()
        local tab = self:AddTab("UI Settings")
        local menu = tab:AddLeftGroupbox("Menu")
        local config = tab:AddRightGroupbox("Configuration")

        menu:AddButton("Unload", function()
            Library:Unload()
        end)

        menu:AddKeyPicker("MenuKeybind", {
            Text = "Menu bind",
            Default = Library.ToggleKeybind,
            Mode = "Toggle"
        }):OnChanged(function(key)
            Library.ToggleKeybind = key
        end)

        config:AddLabel("Config list")

        local selectedConfig = ""
        local configsDropdown

        configsDropdown = config:AddDropdown("ConfigList", {
            Text = "Configs",
            Values = Library:ListConfigs(),
            Default = ""
        }):OnChanged(function(value)
            selectedConfig = value
        end)

        local configName = config:AddInput("ConfigName", {
            Text = "Config name",
            Placeholder = "new config",
            Default = ""
        })

        config:AddButton("Create config", function()
            local name = sanitizeName(configName.Value)
            Library:SaveConfig(name)
            configsDropdown:SetValues(Library:ListConfigs())
            configsDropdown:SetValue(name)
            selectedConfig = name
            Library:Notify("Created config: " .. name, 2)
        end)

        config:AddButton("Load config", function()
            local name = sanitizeName(selectedConfig ~= "" and selectedConfig or configName.Value)
            local ok, err = Library:LoadConfig(name)
            Library:Notify(ok and ("Loaded config: " .. name) or ("Failed: " .. tostring(err)), 2)
        end)

        config:AddButton("Overwrite config", function()
            local name = sanitizeName(selectedConfig ~= "" and selectedConfig or configName.Value)
            local ok, err = Library:SaveConfig(name)
            Library:Notify(ok and ("Saved config: " .. name) or ("Failed: " .. tostring(err)), 2)
        end)

        config:AddButton("Autoload config", function()
            local name = sanitizeName(selectedConfig ~= "" and selectedConfig or configName.Value)
            Library:SetAutoload(name)
            Library:Notify("Autoload set: " .. name, 2)
        end)

        config:AddButton("Refresh config list", function()
            configsDropdown:SetValues(Library:ListConfigs())
            Library:Notify("Config list refreshed", 2)
        end)

        config:AddLabel("Current autoload: " .. Library:GetAutoload())
        return tab
    end

    function Library:Toggle()
        outer.Visible = not outer.Visible
    end

    table.insert(Library.Signals, UIS.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == Library.ToggleKeybind then
            Library:Toggle()
        end
    end))

    Library:MakeDraggable(outer, 28)

    if opts.AutoShow then outer.Visible = true end

    task.defer(function()
        Library:LoadAutoload()
    end)

    return win
end

function Library:Notify(text, duration)
    local frame = create("Frame", {
        Size = UDim2.fromOffset(280, 34),
        Position = UDim2.fromOffset(20, 20),
        BackgroundColor3 = Library.BackgroundColor,
        BorderColor3 = Library.AccentColor,
        Parent = ScreenGui,
        ZIndex = 100
    })

    label({
        Text = tostring(text),
        Size = UDim2.new(1, -10, 1, 0),
        Position = UDim2.fromOffset(5, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = frame,
        ZIndex = 101
    })

    task.delay(duration or 3, function()
        if frame then frame:Destroy() end
    end)
end

function Library:SetWatermark(text)
    if Library.Watermark then Library.Watermark:Destroy() end

    local frame = create("Frame", {
        Size = UDim2.fromOffset(260, 22),
        Position = UDim2.fromOffset(10, 10),
        BackgroundColor3 = Library.BackgroundColor,
        BorderColor3 = Library.AccentColor,
        Parent = ScreenGui,
        ZIndex = 90
    })

    label({
        Text = tostring(text),
        Size = UDim2.new(1, -8, 1, 0),
        Position = UDim2.fromOffset(4, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = frame,
        ZIndex = 91
    })

    Library.Watermark = frame
end

function Library:Unload()
    for _, sig in pairs(Library.Signals) do
        pcall(function() sig:Disconnect() end)
    end

    if ScreenGui then ScreenGui:Destroy() end
end

return Library
