local function safeCall(fn, ...)
    if typeof(fn) == "function" then
        local ok, err = pcall(fn, ...)
        if not ok then warn("[Velocity UI]", err) end
    end
end

local function create(class, props)
    local obj = Instance.new(class)
    for i, v in pairs(props or {}) do
        obj[i] = v
    end
    return obj
end

local function label(props)
    return create("TextLabel", {
        BackgroundTransparency = 1,
        Font = Enum.Font.Code,
        TextColor3 = Library.FontColor,
        TextSize = props.TextSize or 14,
        Text = props.Text or "",
        TextXAlignment = props.TextXAlignment or Enum.TextXAlignment.Center,
        TextYAlignment = props.TextYAlignment or Enum.TextYAlignment.Center,
        Size = props.Size or UDim2.new(1, 0, 0, 16),
        Position = props.Position or UDim2.new(),
        ZIndex = props.ZIndex or 1,
        Parent = props.Parent
    })
end

local function buttonFrame(parent, size)
    local outer = create("Frame", {
        Size = size,
        BackgroundColor3 = Library.MainColor,
        BorderColor3 = Color3.new(0, 0, 0),
        Parent = parent,
        ZIndex = 5
    })

    local inner = create("Frame", {
        Size = UDim2.new(1, -2, 1, -2),
        Position = UDim2.fromOffset(1, 1),
        BackgroundColor3 = Library.SecondaryColor,
        BorderColor3 = Library.OutlineColor,
        Parent = outer,
        ZIndex = 6
    })

    return outer, inner
end

local function updateGroupbox(gb)
    task.defer(function()
        local layout = gb.Container and gb.Container:FindFirstChildOfClass("UIListLayout")
        if layout and gb.Frame then
            gb.Frame.Size = UDim2.new(1, 0, 0, layout.AbsoluteContentSize.Y + 32)
        end
    end)
end

local function ensureFolders()
    if makefolder and not isfolder(Library.Folder) then pcall(makefolder, Library.Folder) end
    if makefolder and not isfolder(Library.ConfigFolder) then pcall(makefolder, Library.ConfigFolder) end
end

local function canFiles()
    return writefile and readfile and isfile and listfiles and makefolder
end

local function sanitizeName(name)
    name = tostring(name or ""):gsub("[^%w_%-%s]", ""):gsub("^%s+", ""):gsub("%s+$", "")
    if name == "" then name = "default" end
    return name
end

local AddonFuncs = {}

function AddonFuncs:AddBlank(size)
    create("Frame", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, size or 6),
        Parent = self.Container
    })
    updateGroupbox(self)
end

function AddonFuncs:AddLabel(text)
    label({
        Text = text,
        Size = UDim2.new(1, -8, 0, 16),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = self.Container,
        ZIndex = 7
    })
    self:AddBlank(4)
end

function AddonFuncs:AddButton(text, callback)
    local outer, inner = buttonFrame(self.Container, UDim2.new(1, -8, 0, 22))
    label({Text = text, Size = UDim2.new(1, 0, 1, 0), Parent = inner, ZIndex = 7})

    outer.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            safeCall(callback)
        end
    end)

    self:AddBlank(6)
    return outer
end

function AddonFuncs:AddToggle(id, info)
    info = info or {}
    local toggle = {Value = info.Default or false, Type = "Toggle"}

    local row = create("Frame", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -8, 0, 18),
        Parent = self.Container,
        ZIndex = 5
    })

    local box = create("Frame", {
        Size = UDim2.fromOffset(13, 13),
        Position = UDim2.fromOffset(0, 2),
        BackgroundColor3 = Library.MainColor,
        BorderColor3 = Library.OutlineColor,
        Parent = row,
        ZIndex = 6
    })

    label({
        Text = info.Text or id,
        Size = UDim2.new(1, -22, 1, 0),
        Position = UDim2.fromOffset(22, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = row,
        ZIndex = 7
    })

    function toggle:SetValue(v)
        self.Value = not not v
        box.BackgroundColor3 = self.Value and Library.AccentColor or Library.MainColor
        box.BorderColor3 = self.Value and Library.AccentColor or Library.OutlineColor
        safeCall(self.Changed, self.Value)
    end

    function toggle:OnChanged(fn)
        self.Changed = fn
        safeCall(fn, self.Value)
        return self
    end

    row.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            toggle:SetValue(not toggle.Value)
        end
    end)

    toggle:SetValue(toggle.Value)
    Toggles[id] = toggle
    self:AddBlank(5)
    return toggle
end

function AddonFuncs:AddInput(id, info)
    info = info or {}
    local input = {Value = info.Default or "", Type = "Input"}

    label({
        Text = info.Text or id,
        Size = UDim2.new(1, -8, 0, 16),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = self.Container,
        ZIndex = 7
    })

    local outer, inner = buttonFrame(self.Container, UDim2.new(1, -8, 0, 24))

    local box = create("TextBox", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -8, 1, 0),
        Position = UDim2.fromOffset(4, 0),
        Font = Enum.Font.Code,
        TextSize = 14,
        TextColor3 = Library.FontColor,
        PlaceholderText = info.Placeholder or "",
        Text = input.Value,
        ClearTextOnFocus = false,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = inner,
        ZIndex = 8
    })

    function input:SetValue(v)
        self.Value = tostring(v or "")
        if box.Text ~= self.Value then box.Text = self.Value end
        safeCall(self.Changed, self.Value)
    end

    function input:OnChanged(fn)
        self.Changed = fn
        safeCall(fn, self.Value)
        return self
    end

    box:GetPropertyChangedSignal("Text"):Connect(function()
        if box.Text ~= input.Value then input:SetValue(box.Text) end
    end)

    Options[id] = input
    self:AddBlank(7)
    return input
end

function AddonFuncs:AddSlider(id, info)
    info = info or {}
    local slider = {
        Value = info.Default or info.Min or 0,
        Min = info.Min or 0,
        Max = info.Max or 100,
        Rounding = info.Rounding or 0,
        Type = "Slider"
    }

    label({
        Text = info.Text or id,
        Size = UDim2.new(1, -8, 0, 16),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = self.Container,
        ZIndex = 7
    })

    local outer, inner = buttonFrame(self.Container, UDim2.new(1, -8, 0, 18))

    local fill = create("Frame", {
        Size = UDim2.new(0, 0, 1, 0),
        BackgroundColor3 = Library.AccentColor,
        BorderSizePixel = 0,
        Parent = inner,
        ZIndex = 7
    })

    local valueLabel = label({Text = "", Size = UDim2.new(1, 0, 1, 0), Parent = inner, ZIndex = 8})

    local function round(v)
        return tonumber(string.format("%." .. slider.Rounding .. "f", v))
    end

    function slider:SetValue(v)
        local nv = math.clamp(tonumber(v) or self.Min, self.Min, self.Max)
        nv = round(nv)
        self.Value = nv
        valueLabel.Text = tostring(nv)
        local percent = (nv - self.Min) / math.max(self.Max - self.Min, 1)
        fill.Size = UDim2.new(percent, 0, 1, 0)
        safeCall(self.Changed, nv)
    end

    function slider:OnChanged(fn)
        self.Changed = fn
        safeCall(fn, self.Value)
        return self
    end

    local dragging = false

    local function update()
        local width = math.max(inner.AbsoluteSize.X, 1)
        local relative = math.clamp(Mouse.X - inner.AbsolutePosition.X, 0, width)
        local percent = relative / width
        slider:SetValue(slider.Min + ((slider.Max - slider.Min) * percent))
    end

    inner.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            update()
        end
    end)

    table.insert(Library.Signals, UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end))

    table.insert(Library.Signals, RS.RenderStepped:Connect(function()
        if dragging then update() end
    end))

    slider:SetValue(slider.Value)
    Options[id] = slider
    self:AddBlank(8)
    return slider
end

function AddonFuncs:AddDropdown(id, info)
    info = info or {}
    local dropdown = {Value = info.Default or "", Values = info.Values or {}, Type = "Dropdown", Open = false}

    label({
        Text = info.Text or id,
        Size = UDim2.new(1, -8, 0, 16),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = self.Container,
        ZIndex = 7
    })

    local outer, inner = buttonFrame(self.Container, UDim2.new(1, -8, 0, 22))
    local txt = label({Text = "", Size = UDim2.new(1, -20, 1, 0), Position = UDim2.fromOffset(5, 0), TextXAlignment = Enum.TextXAlignment.Left, Parent = inner, ZIndex = 7})
    label({Text = "▼", Size = UDim2.fromOffset(18, 18), Position = UDim2.new(1, -18, 0, 1), Parent = inner, ZIndex = 7})

    local listFrame = create("Frame", {
        Size = UDim2.new(1, -8, 0, 0),
        BackgroundColor3 = Library.SecondaryColor,
        BorderColor3 = Library.OutlineColor,
        Visible = false,
        Parent = self.Container,
        ZIndex = 20
    })

    local listLayout = create("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Parent = listFrame})

    local function rebuild()
        for _, child in pairs(listFrame:GetChildren()) do
            if not child:IsA("UIListLayout") then child:Destroy() end
        end

        for _, value in ipairs(dropdown.Values) do
            local item = create("Frame", {
                Size = UDim2.new(1, 0, 0, 20),
                BackgroundColor3 = Library.MainColor,
                BorderColor3 = Library.OutlineColor,
                Parent = listFrame,
                ZIndex = 21
            })
            label({Text = tostring(value), Size = UDim2.new(1, -8, 1, 0), Position = UDim2.fromOffset(4, 0), TextXAlignment = Enum.TextXAlignment.Left, Parent = item, ZIndex = 22})
            item.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    dropdown:SetValue(value)
                    dropdown:SetOpen(false)
                end
            end)
        end

        task.defer(function()
            listFrame.Size = UDim2.new(1, -8, 0, dropdown.Open and listLayout.AbsoluteContentSize.Y or 0)
            updateGroupbox(self)
        end)
    end

    function dropdown:SetOpen(state)
        self.Open = not not state
        listFrame.Visible = self.Open
        task.defer(function()
            listFrame.Size = UDim2.new(1, -8, 0, self.Open and listLayout.AbsoluteContentSize.Y or 0)
            updateGroupbox(self.ParentGroupbox or {Frame = listFrame.Parent, Container = listFrame.Parent})
        end)
    end

    function dropdown:SetValue(v)
        self.Value = tostring(v or "")
        txt.Text = self.Value
        safeCall(self.Changed, self.Value)
    end

    function dropdown:SetValues(values)
        self.Values = values or {}
        rebuild()
    end

    function dropdown:OnChanged(fn)
        self.Changed = fn
        safeCall(fn, self.Value)
        return self
    end

    dropdown.ParentGroupbox = self

    outer.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dropdown:SetOpen(not dropdown.Open)
        end
    end)

    if dropdown.Value == "" and dropdown.Values[1] then dropdown.Value = tostring(dropdown.Values[1]) end
    txt.Text = dropdown.Value
    rebuild()
    Options[id] = dropdown
    self:AddBlank(7)
    return dropdown
end

function AddonFuncs:AddKeyPicker(id, info)
    info = info or {}
    local kp = {
        Value = info.Default or Enum.KeyCode.Unknown,
        Mode = info.Mode or "Toggle",
        Toggled = false,
        Type = "KeyPicker"
    }

    local modes = {"Always", "Toggle", "Hold"}
    local listening = false

    local row = create("Frame", {BackgroundTransparency = 1, Size = UDim2.new(1, -8, 0, 22), Parent = self.Container, ZIndex = 5})
    label({Text = info.Text or id, Size = UDim2.new(1, -112, 1, 0), TextXAlignment = Enum.TextXAlignment.Left, Parent = row, ZIndex = 7})

    local box = create("Frame", {
        Size = UDim2.fromOffset(106, 20),
        Position = UDim2.new(1, -106, 0, 1),
        BackgroundColor3 = Library.SecondaryColor,
        BorderColor3 = Library.OutlineColor,
        Parent = row,
        ZIndex = 6
    })

    local txt = label({Text = "", Size = UDim2.new(1, 0, 1, 0), Parent = box, ZIndex = 7})

    local function keyName(k)
        if typeof(k) == "EnumItem" then return k.Name end
        return "None"
    end

    local function refresh()
        txt.Text = keyName(kp.Value) .. " [" .. kp.Mode .. "]"
    end

    function kp:SetValue(key)
        if typeof(key) == "EnumItem" and key.EnumType == Enum.KeyCode then
            self.Value = key
            refresh()
            safeCall(self.Changed, self.Value, self.Mode, self.Toggled)
        end
    end

    function kp:SetMode(mode)
        if table.find(modes, mode) then
            self.Mode = mode
            refresh()
            safeCall(self.Changed, self.Value, self.Mode, self.Toggled)
        end
    end

    function kp:GetState()
        if self.Mode == "Always" then return true end
        return self.Toggled
    end

    function kp:OnChanged(fn)
        self.Changed = fn
        safeCall(fn, self.Value, self.Mode, self.Toggled)
        return self
    end

    box.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            listening = true
            txt.Text = "Press key..."
        elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
            local current = table.find(modes, kp.Mode) or 2
            kp:SetMode(modes[(current % #modes) + 1])
        end
    end)

    table.insert(Library.Signals, UIS.InputBegan:Connect(function(input, processed)
        if listening then
            if input.UserInputType == Enum.UserInputType.Keyboard then
                listening = false
                kp:SetValue(input.KeyCode)
            elseif input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 then
                listening = false
                refresh()
            end
            return
        end

        if processed or input.UserInputType ~= Enum.UserInputType.Keyboard or input.KeyCode ~= kp.Value then return end

        if kp.Mode == "Toggle" then
            kp.Toggled = not kp.Toggled
        elseif kp.Mode == "Hold" then
            kp.Toggled = true
        elseif kp.Mode == "Always" then
            kp.Toggled = true
        end

        safeCall(kp.Changed, kp.Value, kp.Mode, kp.Toggled)
    end))

    table.insert(Library.Signals, UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == kp.Value and kp.Mode == "Hold" then
            kp.Toggled = false
            safeCall(kp.Changed, kp.Value, kp.Mode, kp.Toggled)
        end
    end))

    refresh()
    Options[id] = kp
    self:AddBlank(7)
    return kp
end

