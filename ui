------------------------- Rainbow Accent Logic -----------------------
local RainbowStep, Hue = 0, 0
table.insert(Library.Signals, RenderStepped:Connect(function(dt)
    RainbowStep = RainbowStep + dt
    if RainbowStep >= (1 / 60) then
        RainbowStep = 0
        Hue = Hue + (1 / 400)
        if Hue > 1 then Hue = 0 end
        Library.CurrentRainbowHue = Hue
        Library.CurrentRainbowColor = Color3.fromHSV(Hue, 0.8, 1)
    end
end))

------------------------- Utility Functions -------------------------

function Library:Create(classtype, props)
    local inst = type(classtype) == "string" and Instance.new(classtype) or classtype
    if props then for p,v in next, props do inst[p] = v end end
    return inst
end

function Library:CreateLabel(props, hud)
    local lbl = Library:Create("TextLabel", {
        BackgroundTransparency=1, Font=Enum.Font.Code, TextColor3=Library.FontColor,
        TextSize=16, TextStrokeTransparency=0,
    })
    Library:AddToRegistry(lbl, {TextColor3="FontColor"}, hud)
    return Library:Create(lbl, props)
end

function Library:GetTextBounds(Text, Font, Size, Res)
    local B = TextService:GetTextSize(Text, Size, Font, Res or Vector2.new(1920,1080))
    return B.X, B.Y
end

function Library:GetDarkerColor(Color)
    local H, S, V = Color3.toHSV(Color)
    return Color3.fromHSV(H, S, V/1.5)
end
Library.AccentColorDark = Library:GetDarkerColor(Library.AccentColor)

function Library:AddToRegistry(Instance, Properties, IsHud)
    local Data = {Instance=Instance, Properties=Properties, Idx=#Library.Registry+1}
    table.insert(Library.Registry, Data)
    Library.RegistryMap[Instance] = Data
    if IsHud then table.insert(Library.HudRegistry, Data) end
end

function Library:RemoveFromRegistry(Instance)
    local Data = Library.RegistryMap[Instance]
    if Data then
        for i=#Library.Registry,1,-1 do if Library.Registry[i]==Data then table.remove(Library.Registry,i) end end
        for i=#Library.HudRegistry,1,-1 do if Library.HudRegistry[i]==Data then table.remove(Library.HudRegistry,i) end end
        Library.RegistryMap[Instance]=nil
    end
end

------------------------- Main UI Controls (Minimal & Modular) -------------------------

-- For brevity & focus, most UI containers, labels, groupbox, toggles, slider, dropdown, input, etc
-- are organized in reusable pattern here. All controls expose :OnChanged(Func) and :SetValue(value)
-- Compose by calling e.g. Window:AddTab(...):AddLeftGroupbox(...):AddToggle(...) etc

local BaseAddons, BaseGroupbox = {}, {}

do
    local AddonFuncs = {}

    function AddonFuncs:AddLabel(text)
        local lbl = Library:CreateLabel({
            Size=UDim2.new(1,-4,0,15), Text=text, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=5, Parent=self.Container
        })
        self:AddBlank(5)
        self:Resize()
        return setmetatable({TextLabel=lbl, Container=self.Container}, BaseAddons)
    end

    function AddonFuncs:AddBlank(size)
        Library:Create("Frame", {BackgroundTransparency=1, Size=UDim2.new(1,0,0,size or 5), ZIndex=1, Parent=self.Container})
    end

    function AddonFuncs:AddButton(text, func)
        local outer = Library:Create("Frame", {BorderColor3=Library.Black, Size=UDim2.new(1,-4,0,20), ZIndex=5, Parent=self.Container})
        local inner = Library:Create("Frame", {
            BackgroundColor3=Library.MainColor, BorderColor3=Library.OutlineColor, BorderMode=Enum.BorderMode.Inset,
            Size=UDim2.new(1,0,1,0), ZIndex=6, Parent=outer
        })
        Library:CreateLabel({Text=text, Size=UDim2.new(1,0,1,0), ZIndex=6, Parent=inner})
        outer.InputBegan:Connect(function(Input) if Input.UserInputType==Enum.UserInputType.MouseButton1 then func() end end)
        self:AddBlank(5)
        self:Resize()
        return setmetatable({}, BaseAddons)
    end

    function AddonFuncs:AddToggle(idx, info)
        local t = {Value=info.Default or false, Type="Toggle"}
        local outer = Library:Create("Frame", {BorderColor3=Library.Black, Size=UDim2.new(0,13,0,13), ZIndex=5, Parent=self.Container})
        local inner = Library:Create("Frame", {BackgroundColor3=Library.MainColor, BorderColor3=Library.OutlineColor,
            BorderMode=Enum.BorderMode.Inset, Size=UDim2.new(1,0,1,0), ZIndex=6, Parent=outer
        })
        local lbl = Library:CreateLabel({
            Size=UDim2.new(0,216,1,0), Position=UDim2.new(1,6,0,0), TextSize=14, Text=info.Text, ZIndex=6, Parent=inner
        })
        function t:SetValue(v)
            local nv = not not v
            t.Value = nv
            inner.BackgroundColor3 = nv and Library.AccentColor or Library.MainColor
            inner.BorderColor3 = nv and Library.AccentColorDark or Library.OutlineColor
            if t.Changed then t.Changed(nv) end
        end
        function t:OnChanged(f) t.Changed = f; f(t.Value) end
        lbl.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then t:SetValue(not t.Value) end end)
        t:SetValue(t.Value)
        self:AddBlank(7)
        self:Resize()
        Toggles[idx] = t
        return setmetatable(t, BaseAddons)
    end

    function AddonFuncs:AddInput(idx, info)
        local t = {Value=info.Default or "", Type="Input"}
        Library:CreateLabel({Size=UDim2.new(1,0,0,15), Text=info.Text, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=5, Parent=self.Container})
        self:AddBlank(1)
        local outer = Library:Create("Frame", {BorderColor3=Library.Black, Size=UDim2.new(1,-4,0,20), ZIndex=5, Parent=self.Container})
        local inner = Library:Create("Frame", {BackgroundColor3=Library.MainColor, BorderColor3=Library.OutlineColor, 
            BorderMode=Enum.BorderMode.Inset, Size=UDim2.new(1,0,1,0), ZIndex=6, Parent=outer})
        local box = Library:Create("TextBox", {
            BackgroundTransparency=1, Position=UDim2.fromOffset(5,0), Size=UDim2.new(1,-8,1,0),
            Font=Enum.Font.Code, Text=info.Default or "", TextColor3 = Library.FontColor,
            PlaceholderText = info.Placeholder or "", TextSize=14, TextStrokeTransparency=0, ZIndex=7, Parent=inner
        })
        function t:SetValue(str)
            t.Value = str
            box.Text = str
            if t.Changed then t.Changed(str) end
        end
        box:GetPropertyChangedSignal("Text"):Connect(function()
            t:SetValue(box.Text)
        end)
        function t:OnChanged(f) t.Changed = f; f(t.Value) end
        self:AddBlank(5)
        self:Resize()
        Options[idx] = t
        return t
    end

    function AddonFuncs:AddSlider(idx, info)
        local t = {Value = info.Default or info.Min, Type="Slider", Min = info.Min, Max = info.Max, Rounding = info.Rounding, MaxSize=190}
        local lbl = Library:CreateLabel({Size=UDim2.new(1,0,0,15), Text=info.Text, TextSize=14, ZIndex=5, Parent=self.Container})
        self:AddBlank(3)
        local outer = Library:Create("Frame", {BorderColor3=Library.Black, Size=UDim2.new(1,-4,0,13), ZIndex=5, Parent=self.Container})
        local inner = Library:Create("Frame", {BackgroundColor3=Library.MainColor, BorderColor3=Library.OutlineColor,
            BorderMode=Enum.BorderMode.Inset, Size=UDim2.new(1,0,1,0), ZIndex=6, Parent=outer })
        local fill = Library:Create("Frame", {BackgroundColor3=Library.AccentColor, Size=UDim2.new(0,0,1,0), ZIndex=7, Parent=inner })
        local slider_lbl = Library:CreateLabel({Size=UDim2.new(1,0,1,0), TextSize=13, Text="", ZIndex=9, Parent=inner })

        local function RoundValue(v) return tonumber(string.format("%." .. (info.Rounding or 0) .. "f", v)) end
        function t:SetValue(v)
            local nv = math.clamp(tonumber(v) or t.Min, t.Min, t.Max)
            nv = RoundValue(nv)
            t.Value = nv
            slider_lbl.Text = tostring(nv)
            fill.Size = UDim2.new((nv - t.Min)/(t.Max-t.Min),0,1,0)
            if t.Changed then t.Changed(nv) end
        end
        function t:OnChanged(f) t.Changed = f; f(t.Value) end
        inner.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                while InputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) do
                    local x = math.clamp(Mouse.X - fill.AbsolutePosition.X, 0, t.MaxSize)
                    local v = t.Min + ((x/t.MaxSize)*(t.Max-t.Min))
                    t:SetValue(RoundValue(v))
                    RenderStepped:Wait()
                end
            end
        end)
        t:SetValue(t.Value)
        self:AddBlank(7)
        self:Resize()
        Options[idx] = t
        return t
    end

    BaseAddons.__index = AddonFuncs
    BaseGroupbox.__index = AddonFuncs
end

