------------------------- Main Window/Tab Setup ----------------------------

function Library:CreateWindow(props)
    local p = type(props)=="table" and props or {Title=props,Size=UDim2.fromOffset(550,600), Position=UDim2.fromOffset(175,50)}
    local Win = {Tabs={}}
    local Outer = Library:Create("Frame", {
        AnchorPoint=p.AnchorPoint or Vector2.zero, BackgroundColor3=Color3.new(0,0,0), BorderSizePixel=0,
        Position=p.Position, Size=p.Size, Visible=false, ZIndex=1, Parent=ScreenGui
    })
    Library:MakeDraggable(Outer, 24)
    local Inner = Library:Create("Frame", {BackgroundColor3=Library.MainColor, BorderColor3=Library.AccentColor,
        BorderMode=Enum.BorderMode.Inset, Position=UDim2.new(0,1,0,1), Size=UDim2.new(1,-2,1,-2), ZIndex=1, Parent=Outer
    })
    local Title = Library:CreateLabel({Text=p.Title or "Title", Size=UDim2.new(1,0,0,24), ZIndex=2, Parent=Inner, TextXAlignment=Enum.TextXAlignment.Center})

    local TabBar = Library:Create("Frame", {BackgroundTransparency=1, Position=UDim2.new(0,8,0,8), Size=UDim2.new(1,-16,0,21), ZIndex=1, Parent=Inner})
    Library:Create("UIListLayout", {Padding=UDim.new(0,0),FillDirection=Enum.FillDirection.Horizontal, SortOrder=Enum.SortOrder.LayoutOrder,Parent=TabBar})

    local TabArea = Library:Create("Frame", {BackgroundColor3=Library.MainColor, BorderColor3=Library.OutlineColor, Position=UDim2.new(0,8,0,32), Size=UDim2.new(1,-16,1,-40), ZIndex=2, Parent=Inner})
    Library:AddToRegistry(TabArea, {BackgroundColor3="MainColor", BorderColor3="OutlineColor"})

    local TabsCreated = {}

    function Win:AddTab(name)
        local tab = {Groupboxes={}}
        local TabBtn = Library:Create("Frame", {BackgroundColor3=Library.BackgroundColor, BorderColor3=Library.OutlineColor, Size=UDim2.new(0, Library:GetTextBounds(name, Enum.Font.Code,16)+18, 1,0), ZIndex=1, Parent=TabBar})
        local TabLbl = Library:CreateLabel({Text=name, Size=UDim2.new(1,0,1,0), ZIndex=2, Parent=TabBtn})
        local TabFrame = Library:Create("Frame", {Name="TabFrame", BackgroundTransparency=1, Size=UDim2.new(1,0,1,0), Visible=false, ZIndex=2, Parent=TabArea})

        -- Left/Right scrolling columns for content
        local LeftScroll = Library:Create("ScrollingFrame", {BackgroundTransparency=1, Position=UDim2.new(0,0,0,0), Size=UDim2.new(0.5, -6, 1,0), ZIndex=2,
            BorderSizePixel=0, AutomaticCanvasSize=Enum.AutomaticSize.Y, CanvasSize=UDim2.new(0,0,0,0), ScrollBarThickness=0, VerticalScrollBarInset=Enum.ScrollBarInset.None, Parent=TabFrame})
        local RightScroll = Library:Create("ScrollingFrame", {BackgroundTransparency=1, Position=UDim2.new(0.5, 6, 0,0), Size=UDim2.new(0.5, -6, 1,0), ZIndex=2,
            BorderSizePixel=0, AutomaticCanvasSize=Enum.AutomaticSize.Y, CanvasSize=UDim2.new(0,0,0,0), ScrollBarThickness=0, VerticalScrollBarInset=Enum.ScrollBarInset.None, Parent=TabFrame})
        Library:Create("UIListLayout", {Padding=UDim.new(0,8),FillDirection=Enum.FillDirection.Vertical,SortOrder=Enum.SortOrder.LayoutOrder,Parent=LeftScroll})
        Library:Create("UIListLayout", {Padding=UDim.new(0,8),FillDirection=Enum.FillDirection.Vertical,SortOrder=Enum.SortOrder.LayoutOrder,Parent=RightScroll})

        function tab:AddLeftGroupbox(title)
            local frame = Library:Create("Frame", {BackgroundColor3=Library.BackgroundColor, BorderColor3=Library.OutlineColor, Size=UDim2.new(1,0,0,55), ZIndex=2,Parent=LeftScroll})
            local label = Library:CreateLabel({Text=title, Size=UDim2.new(1,0,0,20), ZIndex=4, Parent=frame})
            local container = Library:Create("Frame", {BackgroundTransparency=1, Position=UDim2.new(0,4,0,24), Size=UDim2.new(1,-4,1,-24), ZIndex=2, Parent=frame})
            Library:Create("UIListLayout", {FillDirection=Enum.FillDirection.Vertical, SortOrder=Enum.SortOrder.LayoutOrder,Parent=container})
            local gb = {Frame = frame, Container = container}
            setmetatable(gb, BaseGroupbox)
            function gb:Resize() BaseGroupbox.Resize(self) end
            tab.Groupboxes[title]=gb; tab:Resize()
            return gb
        end
        function tab:AddRightGroupbox(title)
            local frame = Library:Create("Frame", {BackgroundColor3=Library.BackgroundColor, BorderColor3=Library.OutlineColor, Size=UDim2.new(1,0,0,55), ZIndex=2,Parent=RightScroll})
            local label = Library:CreateLabel({Text=title, Size=UDim2.new(1,0,0,20), ZIndex=4, Parent=frame})
            local container = Library:Create("Frame", {BackgroundTransparency=1, Position=UDim2.new(0,4,0,24), Size=UDim2.new(1,-4,1,-24), ZIndex=2,Parent=frame})
            Library:Create("UIListLayout", {FillDirection=Enum.FillDirection.Vertical, SortOrder=Enum.SortOrder.LayoutOrder,Parent=container})
            local gb = {Frame = frame, Container = container}
            setmetatable(gb, BaseGroupbox)
            function gb:Resize() BaseGroupbox.Resize(self) end
            tab.Groupboxes[title]=gb; tab:Resize()
            return gb
        end
        function tab:Resize() -- auto resize groupboxes
            for _,gb in next, tab.Groupboxes do if gb.Resize then gb:Resize() end end
        end

        function tab:ShowTab()
            for _,t in pairs(Win.Tabs) do if t ~= tab then t:HideTab() end end
            TabFrame.Visible = true
            TabBtn.BackgroundColor3 = Library.MainColor
        end
        function tab:HideTab()
            TabFrame.Visible = false
            TabBtn.BackgroundColor3 = Library.BackgroundColor
        end
        TabBtn.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then tab:ShowTab() end end)
        Win.Tabs[name] = tab; TabsCreated[#TabsCreated+1]=tab
        if #TabsCreated==1 then tab:ShowTab() end -- First tab autoselect
        return tab
    end

    -- Toggle logic (RightCtrl/RightShift default)
    function Library:Toggle()
        Outer.Visible = not Outer.Visible
    end
    Library:GiveSignal(InputService.InputBegan:Connect(function(Input,Processed)
        if Input.KeyCode==Enum.KeyCode.RightControl or (Input.KeyCode==Enum.KeyCode.RightShift and not Processed) then
            coroutine.wrap(function() Library:Toggle() end)()
        end
    end))

    if p.AutoShow then task.spawn(function() Library:Toggle() end) end

    Win.Holder = Outer
    return Win
end

------------------------- Extra UI Features (Watermark, Notify, etc) ------------------------

function Library:SetWatermarkVisibility(b)
    -- Simple watermark logic
    if not Library.Watermark then
        local f = Library:Create("Frame", {Position=UDim2.fromOffset(60,0), Size=UDim2.fromOffset(200,20), ZIndex=300,Parent=ScreenGui})
        local l = Library:CreateLabel({Text="", Size=UDim2.new(1,0,1,0), ZIndex=310, Parent=f})
        Library.Watermark = f; Library.WatermarkText = l
    end
    Library.Watermark.Visible = b
end
function Library:SetWatermark(text)
    if not Library.Watermark then self:SetWatermarkVisibility(true) end
    Library.WatermarkText.Text = text
end

function Library:Notify(text, time)
    local f = Library:Create("Frame", {Position=UDim2.fromOffset(100,20), Size=UDim2.fromOffset(220,30), ZIndex=400, Parent=ScreenGui})
    local l = Library:CreateLabel({Text=text, Size=UDim2.new(1,0,1,0), ZIndex=410, Parent=f})
    task.spawn(function() wait(time or 3); f:Destroy() end)
end

------------------------- Draggable Logic ------------------------

function Library:MakeDraggable(Frame, Cutoff)
    local holding = false
    Frame.Active = true
    Frame.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            holding = true
            local delta = Vector2.new(Mouse.X-Frame.AbsolutePosition.X, Mouse.Y-Frame.AbsolutePosition.Y)
            if delta.Y > (Cutoff or 30) then return end
            while holding and InputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) do
                Frame.Position = UDim2.new(
                    0, Mouse.X-delta.X+(Frame.Size.X.Offset*Frame.AnchorPoint.X),
                    0, Mouse.Y-delta.Y+(Frame.Size.Y.Offset*Frame.AnchorPoint.Y)
                )
                RenderStepped:Wait()
            end
        end
    end)
    Frame.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            holding = false
        end
    end)
end

-------------------------- General API and unload -----------------------------

function Library:GiveSignal(sig) table.insert(self.Signals, sig) end
function Library:Unload()
    for i = #self.Signals,1,-1 do local s=table.remove(self.Signals,i) s:Disconnect() end
    self.ScreenGui:Destroy()
    if self.OnUnload then self.OnUnload() end
end

return Library
