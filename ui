local Library = {}
Library.AccentColor = Color3.fromRGB(0, 120, 255)
Library.MainColor = Color3.fromRGB(26, 26, 28)
Library.BackgroundColor = Color3.fromRGB(16, 16, 19)
Library.OutlineColor = Color3.fromRGB(45, 45, 50)
