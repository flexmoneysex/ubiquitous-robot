function Library:MakeDraggable(frame, cutoff)
    local dragging = false
    local dragStart
    local startPos

    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local mousePos = Vector2.new(Mouse.X, Mouse.Y)
            local rel = mousePos - frame.AbsolutePosition
            if rel.Y > (cutoff or 30) then return end
            dragging = true
            dragStart = mousePos
            startPos = frame.Position
        end
    end)

    table.insert(Library.Signals, UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end))

    table.insert(Library.Signals, RS.RenderStepped:Connect(function()
        if dragging then
            local delta = Vector2.new(Mouse.X, Mouse.Y) - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end))
end

function Library:GetConfigTable()
    local data = {Toggles = {}, Options = {}}

    for id, toggle in pairs(Toggles) do
        data.Toggles[id] = toggle.Value
    end

    for id, option in pairs(Options) do
        if option.Type == "Input" or option.Type == "Slider" or option.Type == "Dropdown" then
            data.Options[id] = option.Value
        elseif option.Type == "KeyPicker" then
            data.Options[id] = {
                Key = option.Value.Name,
                Mode = option.Mode,
                Toggled = option.Toggled
            }
        end
    end

    return data
end

function Library:LoadConfigTable(data)
    if type(data) ~= "table" then return end

    for id, value in pairs(data.Toggles or {}) do
        if Toggles[id] and Toggles[id].SetValue then
            Toggles[id]:SetValue(value)
        end
    end

    for id, value in pairs(data.Options or {}) do
        local option = Options[id]
        if option then
            if option.Type == "KeyPicker" and type(value) == "table" then
                local key = Enum.KeyCode[value.Key or "Unknown"] or Enum.KeyCode.Unknown
                option:SetValue(key)
                option:SetMode(value.Mode or option.Mode)
                option.Toggled = value.Toggled or false
            elseif option.SetValue then
                option:SetValue(value)
            end
        end
    end
end

function Library:SaveConfig(name)
    if not canFiles() then return false, "file functions unavailable" end
    ensureFolders()
    name = sanitizeName(name)
    local path = Library.ConfigFolder .. "/" .. name .. ".json"
    writefile(path, HttpService:JSONEncode(Library:GetConfigTable()))
    return true
end

function Library:LoadConfig(name)
    if not canFiles() then return false, "file functions unavailable" end
    ensureFolders()
    name = sanitizeName(name)
    local path = Library.ConfigFolder .. "/" .. name .. ".json"
    if not isfile(path) then return false, "config not found" end
    local ok, data = pcall(function()
        return HttpService:JSONDecode(readfile(path))
    end)
    if not ok then return false, "invalid config" end
    Library:LoadConfigTable(data)
    return true
end

function Library:ListConfigs()
    if not canFiles() then return {} end
    ensureFolders()

    local configs = {}
    for _, file in ipairs(listfiles(Library.ConfigFolder)) do
        local name = file:match("([^/\\]+)%.json$")
        if name then table.insert(configs, name) end
    end

    table.sort(configs)
    return configs
end

function Library:SetAutoload(name)
    if not canFiles() then return false end
    ensureFolders()
    name = sanitizeName(name)
    writefile(Library.AutoLoadFile, name)
    return true
end

function Library:GetAutoload()
    if not canFiles() then return "none" end
    ensureFolders()
    if isfile(Library.AutoLoadFile) then
        local name = readfile(Library.AutoLoadFile)
        if name and name ~= "" then return name end
    end
    return "none"
end

function Library:LoadAutoload()
    local name = Library:GetAutoload()
    if name ~= "none" then
        return Library:LoadConfig(name)
    end
end

