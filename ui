local function create(class, props)
    local obj = Instance.new(class)
    for i, v in pairs(props or {}) do
        obj[i] = v
    end
    return obj
end

local function label(props)
    return create("TextLabel", {
        BackgroundTransparency = 1,
        Font = Enum.Font.Code,
        TextColor3 = Library.FontColor,
        TextSize = props.TextSize or 14,
        Text = props.Text or "",
        TextXAlignment = props.TextXAlignment or Enum.TextXAlignment.Center,
        TextYAlignment = Enum.TextYAlignment.Center,
        Size = props.Size or UDim2.new(1, 0, 0, 16),
        Position = props.Position or UDim2.new(),
        ZIndex = props.ZIndex or 1,
        Parent = props.Parent
    })
end

local function buttonFrame(parent, size)
    local outer = create("Frame", {
        Size = size,
        BackgroundColor3 = Library.MainColor,
        BorderColor3 = Color3.new(0, 0, 0),
        Parent = parent,
        ZIndex = 5
    })

    local inner = create("Frame", {
        Size = UDim2.new(1, -2, 1, -2),
        Position = UDim2.fromOffset(1, 1),
        BackgroundColor3 = Library.MainColor,
        BorderColor3 = Library.OutlineColor,
        Parent = outer,
        ZIndex = 6
    })

    return outer, inner
end

local function updateGroupbox(gb)
    task.defer(function()
        local layout = gb.Container:FindFirstChildOfClass("UIListLayout")
        if layout then
            gb.Frame.Size = UDim2.new(1, 0, 0, layout.AbsoluteContentSize.Y + 32)
        end
    end)
end

local AddonFuncs = {}

function AddonFuncs:AddBlank(size)
    create("Frame", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, size or 6),
        Parent = self.Container
    })
    updateGroupbox(self)
end

function AddonFuncs:AddLabel(text)
    label({
        Text = text,
        Size = UDim2.new(1, -8, 0, 16),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = self.Container,
        ZIndex = 7
    })
    self:AddBlank(4)
end

function AddonFuncs:AddButton(text, callback)
    local outer, inner = buttonFrame(self.Container, UDim2.new(1, -8, 0, 22))

    label({
        Text = text,
        Size = UDim2.new(1, 0, 1, 0),
        Parent = inner,
        ZIndex = 7
    })

    outer.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            pcall(callback)
        end
    end)

    self:AddBlank(6)
    return outer
end

function AddonFuncs:AddToggle(id, info)
    info = info or {}

    local toggle = {
        Value = info.Default or false,
        Type = "Toggle"
    }

    local row = create("Frame", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -8, 0, 18),
        Parent = self.Container,
        ZIndex = 5
    })

    local box = create("Frame", {
        Size = UDim2.fromOffset(13, 13),
        Position = UDim2.fromOffset(0, 2),
        BackgroundColor3 = Library.MainColor,
        BorderColor3 = Library.OutlineColor,
        Parent = row,
        ZIndex = 6
    })

    local txt = label({
        Text = info.Text or id,
        Size = UDim2.new(1, -22, 1, 0),
        Position = UDim2.fromOffset(22, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = row,
        ZIndex = 7
    })

    function toggle:SetValue(v)
        self.Value = not not v
        box.BackgroundColor3 = self.Value and Library.AccentColor or Library.MainColor
        box.BorderColor3 = self.Value and Library.AccentColor or Library.OutlineColor
        if self.Changed then
            pcall(self.Changed, self.Value)
        end
    end

    function toggle:OnChanged(fn)
        self.Changed = fn
        pcall(fn, self.Value)
        return self
    end

    row.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            toggle:SetValue(not toggle.Value)
        end
    end)

    toggle:SetValue(toggle.Value)
    Toggles[id] = toggle

    self:AddBlank(5)
    return toggle
end

function AddonFuncs:AddInput(id, info)
    info = info or {}

    local input = {
        Value = info.Default or "",
        Type = "Input"
    }

    label({
        Text = info.Text or id,
        Size = UDim2.new(1, -8, 0, 16),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = self.Container,
        ZIndex = 7
    })

    local outer, inner = buttonFrame(self.Container, UDim2.new(1, -8, 0, 24))

    local box = create("TextBox", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -8, 1, 0),
        Position = UDim2.fromOffset(4, 0),
        Font = Enum.Font.Code,
        TextSize = 14,
        TextColor3 = Library.FontColor,
        PlaceholderText = info.Placeholder or "",
        Text = input.Value,
        ClearTextOnFocus = false,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = inner,
        ZIndex = 8
    })

    function input:SetValue(v)
        self.Value = tostring(v or "")
        if box.Text ~= self.Value then
            box.Text = self.Value
        end
        if self.Changed then
            pcall(self.Changed, self.Value)
        end
    end

    function input:OnChanged(fn)
        self.Changed = fn
        pcall(fn, self.Value)
        return self
    end

    box:GetPropertyChangedSignal("Text"):Connect(function()
        if box.Text ~= input.Value then
            input:SetValue(box.Text)
        end
    end)

    Options[id] = input
    self:AddBlank(7)
    return input
end

function AddonFuncs:AddSlider(id, info)
    info = info or {}

    local slider = {
        Value = info.Default or info.Min or 0,
        Min = info.Min or 0,
        Max = info.Max or 100,
        Rounding = info.Rounding or 0,
        Type = "Slider"
    }

    label({
        Text = info.Text or id,
        Size = UDim2.new(1, -8, 0, 16),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = self.Container,
        ZIndex = 7
    })

    local outer, inner = buttonFrame(self.Container, UDim2.new(1, -8, 0, 18))

    local fill = create("Frame", {
        Size = UDim2.new(0, 0, 1, 0),
        BackgroundColor3 = Library.AccentColor,
        BorderSizePixel = 0,
        Parent = inner,
        ZIndex = 7
    })

    local valueLabel = label({
        Text = "",
        Size = UDim2.new(1, 0, 1, 0),
        Parent = inner,
        ZIndex = 8
    })

    local function round(v)
        return tonumber(string.format("%." .. slider.Rounding .. "f", v))
    end

    function slider:SetValue(v)
        local nv = math.clamp(tonumber(v) or self.Min, self.Min, self.Max)
        nv = round(nv)

        self.Value = nv
        valueLabel.Text = tostring(nv)

        local percent = (nv - self.Min) / (self.Max - self.Min)
        fill.Size = UDim2.new(percent, 0, 1, 0)

        if self.Changed then
            pcall(self.Changed, nv)
        end
    end

    function slider:OnChanged(fn)
        self.Changed = fn
        pcall(fn, self.Value)
        return self
    end

    local dragging = false

    local function update()
        local relative = math.clamp(Mouse.X - inner.AbsolutePosition.X, 0, inner.AbsoluteSize.X)
        local percent = relative / inner.AbsoluteSize.X
        slider:SetValue(slider.Min + ((slider.Max - slider.Min) * percent))
    end

    inner.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            update()
        end
    end)

    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    RS.RenderStepped:Connect(function()
        if dragging then
            update()
        end
    end)

    slider:SetValue(slider.Value)
    Options[id] = slider

    self:AddBlank(8)
    return slider
end

local GroupboxMeta = {}
GroupboxMeta.__index = AddonFuncs

function Library:MakeDraggable(frame, cutoff)
    local dragging = false
    local dragStart
    local startPos

    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local mousePos = Vector2.new(Mouse.X, Mouse.Y)
            local rel = mousePos - frame.AbsolutePosition

            if rel.Y > (cutoff or 30) then
                return
            end

            dragging = true
            dragStart = mousePos
            startPos = frame.Position
        end
    end)

    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    RS.RenderStepped:Connect(function()
        if dragging then
            local delta = Vector2.new(Mouse.X, Mouse.Y) - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
end

function Library:CreateWindow(opts)
    opts = opts or {}

    local size = opts.Size or UDim2.fromOffset(550, 600)

    local outer = create("Frame", {
        Size = size,
        AnchorPoint = opts.Center and Vector2.new(0.5, 0.5) or Vector2.zero,
        Position = opts.Center and UDim2.fromScale(0.5, 0.5) or (opts.Position or UDim2.fromOffset(100, 100)),
        BackgroundColor3 = Color3.new(0, 0, 0),
        BorderSizePixel = 0,
        Visible = false,
        Parent = ScreenGui,
        ZIndex = 1
    })

    local inner = create("Frame", {
        Size = UDim2.new(1, -2, 1, -2),
        Position = UDim2.fromOffset(1, 1),
        BackgroundColor3 = Library.MainColor,
        BorderColor3 = Library.AccentColor,
        Parent = outer,
        ZIndex = 2
    })

    label({
        Text = opts.Title or "Velocity",
        Size = UDim2.new(1, 0, 0, 26),
        Parent = inner,
        ZIndex = 3
    })

    local tabBar = create("Frame", {
        BackgroundTransparency = 1,
        Position = UDim2.fromOffset(8, 8),
        Size = UDim2.new(1, -16, 0, 22),
        Parent = inner,
        ZIndex = 4
    })

    create("UIListLayout", {
        FillDirection = Enum.FillDirection.Horizontal,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 4),
        Parent = tabBar
    })

    local tabArea = create("Frame", {
        BackgroundColor3 = Library.MainColor,
        BorderColor3 = Library.OutlineColor,
        Position = UDim2.fromOffset(8, 34),
        Size = UDim2.new(1, -16, 1, -42),
        Parent = inner,
        ZIndex = 3
    })

    local win = {
        Tabs = {},
        Holder = outer
    }

    local firstTab

    function win:AddTab(name)
        local tab = {
            Groupboxes = {}
        }

        local width = TS:GetTextSize(name, 16, Enum.Font.Code, Vector2.new(1000, 1000)).X + 20

        local tabButton = create("Frame", {
            Size = UDim2.fromOffset(width, 22),
            BackgroundColor3 = Library.BackgroundColor,
            BorderColor3 = Library.OutlineColor,
            Parent = tabBar,
            ZIndex = 5
        })

        label({
            Text = name,
            Size = UDim2.new(1, 0, 1, 0),
            Parent = tabButton,
            ZIndex = 6
        })

        local tabFrame = create("Frame", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Visible = false,
            Parent = tabArea,
            ZIndex = 4
        })

        local left = create("ScrollingFrame", {
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            Size = UDim2.new(0.5, -6, 1, -8),
            Position = UDim2.fromOffset(4, 4),
            CanvasSize = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            ScrollBarThickness = 2,
            Parent = tabFrame,
            ZIndex = 5
        })

        local right = create("ScrollingFrame", {
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            Size = UDim2.new(0.5, -6, 1, -8),
            Position = UDim2.new(0.5, 2, 0, 4),
            CanvasSize = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            ScrollBarThickness = 2,
            Parent = tabFrame,
            ZIndex = 5
        })

        create("UIListLayout", {
            Padding = UDim.new(0, 8),
            SortOrder = Enum.SortOrder.LayoutOrder,
            Parent = left
        })

        create("UIListLayout", {
            Padding = UDim.new(0, 8),
            SortOrder = Enum.SortOrder.LayoutOrder,
            Parent = right
        })

        local function addGroupbox(parent, title)
            local frame = create("Frame", {
                Size = UDim2.new(1, -4, 0, 60),
                BackgroundColor3 = Library.BackgroundColor,
                BorderColor3 = Library.OutlineColor,
                Parent = parent,
                ZIndex = 6
            })

            label({
                Text = title,
                Size = UDim2.new(1, 0, 0, 22),
                Parent = frame,
                ZIndex = 7
            })

            local container = create("Frame", {
                BackgroundTransparency = 1,
                Position = UDim2.fromOffset(8, 26),
                Size = UDim2.new(1, -12, 1, -28),
                Parent = frame,
                ZIndex = 7
            })

            create("UIListLayout", {
                SortOrder = Enum.SortOrder.LayoutOrder,
                Padding = UDim.new(0, 0),
                Parent = container
            })

            local gb = setmetatable({
                Frame = frame,
                Container = container
            }, GroupboxMeta)

            task.defer(function()
                updateGroupbox(gb)
            end)

            return gb
        end

        function tab:AddLeftGroupbox(title)
            local gb = addGroupbox(left, title)
            self.Groupboxes[title] = gb
            return gb
        end

        function tab:AddRightGroupbox(title)
            local gb = addGroupbox(right, title)
            self.Groupboxes[title] = gb
            return gb
        end

        function tab:ShowTab()
            for _, other in pairs(win.Tabs) do
                other.Frame.Visible = false
                other.Button.BackgroundColor3 = Library.BackgroundColor
            end

            tabFrame.Visible = true
            tabButton.BackgroundColor3 = Library.MainColor
        end

        tab.Frame = tabFrame
        tab.Button = tabButton

        tabButton.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                tab:ShowTab()
            end
        end)

        win.Tabs[name] = tab

        if not firstTab then
            firstTab = tab
            tab:ShowTab()
        end

        return tab
    end

    function Library:Toggle()
        outer.Visible = not outer.Visible
    end

    table.insert(Library.Signals, UIS.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.KeyCode == Enum.KeyCode.RightControl or input.KeyCode == Enum.KeyCode.RightShift then
            Library:Toggle()
        end
    end))

    Library:MakeDraggable(outer, 28)

    if opts.AutoShow then
        outer.Visible = true
    end

    return win
end

function Library:Notify(text, duration)
    local frame = create("Frame", {
        Size = UDim2.fromOffset(260, 34),
        Position = UDim2.fromOffset(20, 20),
        BackgroundColor3 = Library.BackgroundColor,
        BorderColor3 = Library.AccentColor,
        Parent = ScreenGui,
        ZIndex = 100
    })

    label({
        Text = tostring(text),
        Size = UDim2.new(1, -10, 1, 0),
        Position = UDim2.fromOffset(5, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = frame,
        ZIndex = 101
    })

    task.delay(duration or 3, function()
        if frame then
            frame:Destroy()
        end
    end)
end

function Library:SetWatermark(text)
    if Library.Watermark then
        Library.Watermark:Destroy()
    end

    local frame = create("Frame", {
        Size = UDim2.fromOffset(260, 22),
        Position = UDim2.fromOffset(10, 10),
        BackgroundColor3 = Library.BackgroundColor,
        BorderColor3 = Library.AccentColor,
        Parent = ScreenGui,
        ZIndex = 90
    })

    label({
        Text = tostring(text),
        Size = UDim2.new(1, -8, 1, 0),
        Position = UDim2.fromOffset(4, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = frame,
        ZIndex = 91
    })

    Library.Watermark = frame
end

function Library:Unload()
    for _, sig in pairs(Library.Signals) do
        pcall(function()
            sig:Disconnect()
        end)
    end

    if ScreenGui then
        ScreenGui:Destroy()
    end
end

return Library
